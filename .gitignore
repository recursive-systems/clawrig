# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
clawrig-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/node_modules/
/assets/node_modules/
/playwright-report/
/test-results/
/.tmp/
/wizard-state.json
/.oobe-complete
/priv/node-identity.json
/priv/dashboard-auth.json

# Deploy build artifacts
/deploy/bundle/
/deploy/*.tar.gz
/deploy/pi-gen/pi-gen-repo/
# Staged copies (generated by build-image.sh, not source files)
/deploy/pi-gen/stage-clawrig/01-install-clawrig/files/clawrig.tar.gz
/deploy/pi-gen/stage-clawrig/01-install-clawrig/files/clawrig.service
/deploy/pi-gen/stage-clawrig/02-configure-networking/files/dnsmasq-captive.conf
/deploy/pi-gen/stage-clawrig/02-configure-networking/files/clawrig-avahi.service
