        "restart_gateway",
        "run_doctor",
        "clear_tmp",
        "reinstall_openclaw",
        "reboot",
        "escalate"
      ],
      "description": "The single repair action to take, or 'none' if the system is healthy"
    },
    "reason": {
      "type": "string",
      "description": "Brief explanation of why this action was chosen"
