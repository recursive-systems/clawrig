<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ClawRig Wi-Fi Setup</title>
    <style>
      :root {
        --bg: #0F172A;
        --card: rgba(30,41,59,0.92);
        --border: rgba(255,255,255,0.06);
        --ink: #F8FAFC;
        --ink-bright: #fff;
        --ink-secondary: #94A3B8;
        --signal: #EAB308;
        --signal-light: #FACC15;
        --signal-glow: rgba(234,179,8,0.12);
        --go: #22C55E;
        --stop: #ef4444;
      }
      * { box-sizing: border-box; margin: 0; }
      body {
        min-height: 100vh; font-family: 'Source Serif 4', 'Georgia', serif;
        color: var(--ink); background: var(--bg); display: grid; place-items: center;
        padding: 16px; -webkit-font-smoothing: antialiased;
      }
      .wifi-card {
        width: min(440px, 96vw); background: var(--card); border: 1px solid var(--border);
        border-radius: 16px; padding: 28px 24px; box-shadow: 0 24px 80px rgba(0,0,0,0.5);
      }
      .wifi-header { text-align: center; margin-bottom: 20px; }
      .wifi-logo {
        font-size: 1rem; font-weight: 700; color: var(--ink-bright);
        letter-spacing: -0.02em; margin-bottom: 12px;
      }
      .wifi-logo::before { content: none; }
      .wifi-header h1 { font-size: 1.2rem; color: var(--ink-bright); margin-bottom: 4px; }
      .wifi-header p { color: var(--ink-secondary); font-size: 0.9rem; }
      .wifi-error {
        background: rgba(239,68,68,0.1); color: var(--stop); padding: 10px 14px;
        border-radius: 8px; font-size: 0.88rem; margin-bottom: 14px;
      }
      .wifi-label {
        display: block; font-size: 0.78rem; font-weight: 600; color: var(--ink-secondary);
        text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px;
      }
      .wifi-networks {
        display: flex; flex-direction: column; gap: 4px;
        max-height: 200px; overflow-y: auto; margin-bottom: 16px;
      }
      .wifi-network {
        display: flex; align-items: center; gap: 10px; padding: 10px 12px;
        border-radius: 8px; border: 1px solid var(--border); cursor: pointer;
        transition: background 150ms ease;
      }
      .wifi-network:hover { background: rgba(255,255,255,0.04); }
      .wifi-network input[type="radio"] { accent-color: var(--signal); }
      .wifi-network-name { flex: 1; font-size: 0.92rem; color: var(--ink-bright); }
      .wifi-signal { font-size: 0.75rem; color: var(--ink-secondary); letter-spacing: 0.05em; }
      .wifi-lock { font-size: 0.7rem; }
      .wifi-input {
        width: 100%; padding: 11px 14px; border-radius: 8px;
        border: 1.5px solid var(--border); background: rgba(255,255,255,0.04);
        color: var(--ink-bright); font-size: 0.9rem; outline: none;
        margin-bottom: 16px; font-family: inherit;
      }
      .wifi-input:focus { border-color: var(--signal); box-shadow: 0 0 0 3px var(--signal-glow); }
      .wifi-btn {
        width: 100%; padding: 12px; border: 0; border-radius: 10px;
        background: var(--signal); color: #0F172A; font-size: 0.92rem; font-weight: 600;
        cursor: pointer; font-family: inherit;
      }
      .wifi-btn:hover { background: var(--signal-light); }
      .wifi-btn-subtle {
        display: block; width: 100%; text-align: center; padding: 10px;
        background: rgba(255,255,255,0.06); color: var(--ink-secondary); border: 0;
        border-radius: 8px; font-size: 0.85rem; cursor: pointer; font-family: inherit;
        text-decoration: none;
      }
      .wifi-btn-subtle:hover { background: rgba(255,255,255,0.1); color: var(--ink); }
      .wifi-rescan { margin-top: 10px; }
      .wifi-form { margin-bottom: 0; }
      .wifi-transition { text-align: center; padding: 20px 0; }
      .wifi-spinner {
        width: 40px; height: 40px; border: 3px solid var(--border);
        border-top-color: var(--signal); border-radius: 50%;
        animation: spin 800ms linear infinite; margin: 0 auto 16px;
      }
      .wifi-next-step { font-size: 0.95rem; color: var(--ink); line-height: 1.6; margin-bottom: 12px; }
      .wifi-next-step strong { color: var(--ink-bright); font-size: 1.05rem; }
      .wifi-fallback { font-size: 0.82rem; color: var(--ink-secondary); }
      .wifi-status { padding: 12px 0; }
      .wifi-status p { margin-bottom: 8px; color: var(--ink-secondary); font-size: 0.9rem; }
      .wifi-status strong { color: var(--ink-bright); }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
