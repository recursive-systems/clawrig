<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ClawRig Wi-Fi Setup</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');
      :root {
        --bg: #0e0f13;
        --card: rgba(22,24,33,0.92);
        --card-border: rgba(255,255,255,0.06);
        --ink: #e8e6e3;
        --ink-bright: #fff;
        --muted: #7a7d8e;
        --line: rgba(255,255,255,0.08);
        --accent: #f0734c;
        --accent-2: #ff9a76;
        --accent-glow: rgba(240,115,76,0.15);
        --ok: #3dd68c;
        --err: #ef4444;
      }
      * { box-sizing: border-box; margin: 0; }
      body {
        min-height: 100vh; font-family: 'DM Sans', -apple-system, sans-serif;
        color: var(--ink); background: var(--bg); display: grid; place-items: center;
        padding: 16px; -webkit-font-smoothing: antialiased;
      }
      .wifi-card {
        width: min(440px, 96vw); background: var(--card); border: 1px solid var(--card-border);
        border-radius: 16px; padding: 28px 24px; box-shadow: 0 24px 80px rgba(0,0,0,0.5);
      }
      .wifi-header { text-align: center; margin-bottom: 20px; }
      .wifi-logo {
        font-size: 1rem; font-weight: 700; color: var(--ink-bright);
        letter-spacing: -0.02em; margin-bottom: 12px;
      }
      .wifi-logo::before { content: '\1F99E '; }
      .wifi-header h1 { font-size: 1.2rem; color: var(--ink-bright); margin-bottom: 4px; }
      .wifi-header p { color: var(--muted); font-size: 0.9rem; }
      .wifi-error {
        background: rgba(239,68,68,0.1); color: var(--err); padding: 10px 14px;
        border-radius: 8px; font-size: 0.88rem; margin-bottom: 14px;
      }
      .wifi-label {
        display: block; font-size: 0.78rem; font-weight: 600; color: var(--muted);
        text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px;
      }
      .wifi-networks {
        display: flex; flex-direction: column; gap: 4px;
        max-height: 200px; overflow-y: auto; margin-bottom: 16px;
      }
      .wifi-network {
        display: flex; align-items: center; gap: 10px; padding: 10px 12px;
        border-radius: 8px; border: 1px solid var(--line); cursor: pointer;
        transition: background 150ms ease;
      }
      .wifi-network:hover { background: rgba(255,255,255,0.04); }
      .wifi-network input[type="radio"] { accent-color: var(--accent); }
      .wifi-network-name { flex: 1; font-size: 0.92rem; color: var(--ink-bright); }
      .wifi-signal { font-size: 0.75rem; color: var(--muted); letter-spacing: 0.05em; }
      .wifi-lock { font-size: 0.7rem; }
      .wifi-input {
        width: 100%; padding: 11px 14px; border-radius: 8px;
        border: 1.5px solid var(--line); background: rgba(255,255,255,0.04);
        color: var(--ink-bright); font-size: 0.9rem; outline: none;
        margin-bottom: 16px; font-family: inherit;
      }
      .wifi-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
      .wifi-btn {
        width: 100%; padding: 12px; border: 0; border-radius: 10px;
        background: var(--accent); color: #fff; font-size: 0.92rem; font-weight: 600;
        cursor: pointer; font-family: inherit;
      }
      .wifi-btn:hover { background: var(--accent-2); }
      .wifi-btn-subtle {
        display: block; width: 100%; text-align: center; padding: 10px;
        background: rgba(255,255,255,0.06); color: var(--muted); border: 0;
        border-radius: 8px; font-size: 0.85rem; cursor: pointer; font-family: inherit;
        text-decoration: none;
      }
      .wifi-btn-subtle:hover { background: rgba(255,255,255,0.1); color: var(--ink); }
      .wifi-rescan { margin-top: 10px; }
      .wifi-form { margin-bottom: 0; }
      .wifi-transition { text-align: center; padding: 20px 0; }
      .wifi-spinner {
        width: 40px; height: 40px; border: 3px solid var(--line);
        border-top-color: var(--accent); border-radius: 50%;
        animation: spin 800ms linear infinite; margin: 0 auto 16px;
      }
      .wifi-next-step { font-size: 0.95rem; color: var(--ink); line-height: 1.6; margin-bottom: 12px; }
      .wifi-next-step strong { color: var(--ink-bright); font-size: 1.05rem; }
      .wifi-fallback { font-size: 0.82rem; color: var(--muted); }
      .wifi-status { padding: 12px 0; }
      .wifi-status p { margin-bottom: 8px; color: var(--muted); font-size: 0.9rem; }
      .wifi-status strong { color: var(--ink-bright); }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
