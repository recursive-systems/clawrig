<section class="dashboard">
  <header class="shell-head">
    <h1>
      <img src={~p"/images/favicon.png"} alt="" class="shell-logo" />
      <span class="shell-wordmark">Claw<span class="rig">Rig</span></span>
      <span :if={@preview_scenario} class="preview-badge">Preview: {@preview_scenario}</span>
    </h1>
    <span class="version">v{@version}</span>
  </header>

  <%!-- Update notification banner (visible on all tabs) --%>
  <div :if={@update_status == :downloading} class="update-banner update-progress">
    <span class="update-spinner"></span>
    <span>Downloading update v{@update_version}...</span>
  </div>
  <div :if={@update_status == :installing} class="update-banner update-progress">
    <span class="update-spinner"></span>
    <span>Installing update v{@update_version}...</span>
  </div>
  <div :if={@update_status == :updated} class="update-banner update-success">
    Updated to v{@update_version}. Restarting...
  </div>

  <nav class="dash-nav" role="tablist">
    <.link
      patch={~p"/"}
      class={tab_class(@live_action, :index)}
      aria-current={if @live_action == :index, do: "page", else: nil}
    >
      Dashboard
    </.link>
    <.link
      patch={~p"/wifi"}
      class={tab_class(@live_action, :wifi)}
      aria-current={if @live_action == :wifi, do: "page", else: nil}
    >
      Wi-Fi
    </.link>
    <.link
      patch={~p"/account"}
      class={tab_class(@live_action, :account)}
      aria-current={if @live_action == :account, do: "page", else: nil}
    >
      Provider
    </.link>
    <.link
      patch={~p"/telegram"}
      class={tab_class(@live_action, :telegram)}
      aria-current={if @live_action == :telegram, do: "page", else: nil}
    >
      Telegram
    </.link>
    <.link
      patch={~p"/integrations"}
      class={tab_class(@live_action, :integrations)}
      aria-current={if @live_action == :integrations, do: "page", else: nil}
    >
      Integrations
    </.link>
    <.link
      patch={~p"/system"}
      class={tab_class(@live_action, :system)}
      aria-current={if @live_action == :system, do: "page", else: nil}
    >
      System
    </.link>
  </nav>

  <section class="dash-content" aria-live="polite">
    <% bootstrapping? = @live_action == :index and (@gateway_status == :loading or @internet == :loading or @openai_status == :loading) %>

    <.dash_panel :if={@live_action == :index}>
      <div :if={bootstrapping?} class="setup-inline-banner">
        <strong>Setting things up…</strong>
        <span>We’re finishing first-time checks. This usually takes a few seconds.</span>
      </div>

      <%!-- Dashboard / Status Overview --%>
      <div class="status-grid">
        <div class="status-item">
          <span class="status-label">OpenClaw Gateway</span>
          <span class={["status-value", status_color(@gateway_status)]}>
            {status_label(@gateway_status)}
          </span>
        </div>
        <div class="status-item">
          <span class="status-label">Internet</span>
          <span class={["status-value", status_color(@internet)]}>
            {status_label(@internet)}
          </span>
        </div>
        <div class="status-item">
          <span class="status-label">Wi-Fi Network</span>
          <span class={[
            "status-value",
            cond do
              @wifi_ssid == :loading -> "loading"
              @wifi_ssid -> "ok"
              true -> "warn"
            end
          ]}>
            {cond do
              @wifi_ssid == :loading -> "Checking..."
              @wifi_ssid -> @wifi_ssid
              true -> "Not connected"
            end}
          </span>
        </div>
        <div class="status-item">
          <span class="status-label">Ethernet</span>
          <span class={["status-value", if(@ethernet_connected, do: "ok", else: "warn")]}>
            {if @ethernet_connected, do: "Connected", else: "Not connected"}
          </span>
        </div>
        <div class="status-item">
          <span class="status-label">Node Connection</span>
          <span class={["status-value", status_color(@node_status)]}>
            {status_label(@node_status)}
          </span>
        </div>
        <div class="status-item">
          <span class="status-label">AI Provider</span>
          <span class={["status-value", status_color(@openai_status)]}>
            {status_label(@openai_status)}
          </span>
        </div>
      </div>
    </.dash_panel>

    <%!-- Wi-Fi --%>
    <.dash_panel :if={@live_action == :wifi} title="Wi-Fi Networks" back>
      <:actions>
        <button class="btn subtle btn-sm" phx-click="scan_wifi" phx-target="#wifi-scanner">
          Scan
        </button>
      </:actions>
      <.live_component module={ClawrigWeb.WifiComponent} id="wifi-scanner" wifi_ssid={@wifi_ssid} />
    </.dash_panel>

    <%!-- Account --%>
    <.dash_panel :if={@live_action == :account} title="AI Provider" back>
      <%!-- Connected --%>
      <div :if={@account_sub == :idle and @openai_status == :connected} class="account-section">
        <div class="account-status account-connected">
          <div class="account-badge">
            <svg class="account-check-svg" viewBox="0 0 52 52">
              <circle class="account-check-circle" cx="26" cy="26" r="24" fill="none" />
              <path class="account-check-mark" fill="none" d="M15 27l7 7 15-15" />
            </svg>
          </div>
          <span>
            <%= if @account_provider_type == "openai-compatible" do %>
              Connected to custom provider.
            <% else %>
              Your OpenAI account is configured.
            <% end %>
          </span>
        </div>
        <div class="account-actions">
          <button
            class="btn subtle btn-sm"
            phx-click="disconnect_provider"
            data-confirm="Disconnect your AI provider? You can re-authenticate at any time."
          >
            Disconnect
          </button>
        </div>
      </div>

      <%!-- Choose provider type --%>
      <div :if={@account_sub == :choose_type} class="account-section account-choose">
        <p class="account-lead">Connect an AI provider to use the gateway.</p>
        <div class="provider-type-cards">
          <button class="provider-type-card" phx-click="account_choose_openai">
            <div class="provider-type-icon">
              <img alt="OpenAI" src={~p"/images/openai-mark.svg"} />
            </div>
            <div class="provider-type-info">
              <strong>OpenAI</strong>
              <span>Sign in or use an API key</span>
            </div>
          </button>
          <button class="provider-type-card" phx-click="account_choose_compatible">
            <div class="provider-type-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z" />
                <path d="M2 17l10 5 10-5" />
                <path d="M2 12l10 5 10-5" />
              </svg>
            </div>
            <div class="provider-type-info">
              <strong>Other Provider</strong>
              <span>LiteLLM, Fireworks, Groq, or any OpenAI-compatible API</span>
            </div>
          </button>
        </div>
      </div>

      <%!-- OpenAI: choose auth method --%>
      <div :if={@account_sub == :choose} class="account-section account-choose">
        <p class="account-lead">Connect your OpenAI account to use the gateway.</p>
        <button class="btn openai" phx-click="account_start_device_code">
          <img alt="" src={~p"/images/openai-mark.svg"} /> Sign in with OpenAI
        </button>
        <button class="btn subtle" phx-click="account_use_api_key">
          Use API key instead
        </button>
        <button class="btn ghost btn-sm mt-md" phx-click="account_back_to_type">
          Back
        </button>
      </div>

      <%!-- OpenAI: device code polling --%>
      <div
        :if={@account_sub == :device_code}
        class="account-section"
        id="account-device-code"
        phx-hook="PageFocus"
      >
        <h3>Sign in with OpenAI</h3>
        <p>Scan the QR code with your phone, then enter the code to authorize this device.</p>

        <div class="openai-qr-row">
          <div
            class="tg-qr"
            id="account-qr-device"
            phx-hook="QRCode"
            data-url="https://auth.openai.com/codex/device"
          >
          </div>
          <p class="tg-qr-label">
            Scan to open <strong>auth.openai.com</strong>
          </p>
        </div>

        <div :if={@openai_user_code} class="device-code-display">
          <span class="device-code-value" id="account-device-code-text">{@openai_user_code}</span>
          <button
            class="btn subtle btn-sm"
            id="account-copy-device-code"
            phx-hook="CopyToClipboard"
            data-text={@openai_user_code}
          >
            Copy
          </button>
        </div>

        <div :if={@openai_polling} class="tg-polling">
          <div class="tg-polling-dot"></div>
          <span>Waiting for authorization...</span>
        </div>

        <button class="btn ghost btn-sm" phx-click="account_back_to_choose">
          Cancel
        </button>
      </div>

      <%!-- OpenAI: API key paste --%>
      <div :if={@account_sub == :api_key} class="account-section">
        <h3>API key</h3>
        <p>Paste your OpenAI API key to connect.</p>
        <form phx-submit="account_submit_api_key" class="account-input-group">
          <label for="account-api-key-input">API key</label>
          <input
            type="password"
            name="api_key"
            id="account-api-key-input"
            class={["account-input", @account_error && "error"]}
            placeholder="sk-..."
            autocomplete="off"
            spellcheck="false"
          />
          <p :if={@account_error} class="account-input-hint error">{@account_error}</p>
          <p :if={!@account_error} class="account-input-hint">
            Starts with <code>sk-</code>
          </p>
          <button type="submit" class="btn primary">
            Save API key
          </button>
        </form>
        <button class="btn ghost btn-sm" phx-click="account_back_to_choose">
          Back
        </button>
      </div>

      <%!-- Compatible: endpoint form --%>
      <div :if={@account_sub == :compat_form} class="account-section">
        <h3>Connect Provider</h3>
        <p>Enter your provider's OpenAI-compatible endpoint details.</p>
        <form phx-submit="account_submit_compatible" class="account-input-group">
          <label for="account-base-url-input">Base URL</label>
          <input
            type="url"
            name="base_url"
            id="account-base-url-input"
            class="account-input"
            placeholder="https://litellm.example.com/v1"
            autocomplete="off"
          />
          <p class="account-input-hint">The /v1 endpoint of your provider</p>

          <label for="account-compat-api-key-input" class="mt-md">API Key</label>
          <input
            type="password"
            name="api_key"
            id="account-compat-api-key-input"
            class="account-input"
            placeholder="sk-..."
            autocomplete="off"
          />

          <label for="account-model-id-input" class="mt-md">Model ID</label>
          <input
            type="text"
            name="model_id"
            id="account-model-id-input"
            class="account-input"
            placeholder="gpt-4o"
            autocomplete="off"
          />
          <p class="account-input-hint">The model identifier your provider expects</p>

          <label for="account-display-name-input" class="mt-md">Display Name <span class="openai-input-optional">(optional)</span></label>
          <input
            type="text"
            name="display_name"
            id="account-display-name-input"
            class="account-input"
            placeholder="My LiteLLM Proxy"
            autocomplete="off"
          />

          <p :if={@account_error} class="account-input-hint error mt-sm">
            {@account_error}
          </p>

          <button type="submit" class="btn primary mt-lg">
            Connect
          </button>
        </form>
        <button class="btn ghost btn-sm mt-sm" phx-click="account_back_to_type">
          Back
        </button>
      </div>

      <%!-- Saving --%>
      <div :if={@account_sub == :saving} class="account-section account-saving">
        <div class="check-icon-wrap">
          <div class="check-spinner"></div>
        </div>
        <p>Saving...</p>
      </div>

      <%!-- Error --%>
      <div :if={@account_sub == :error} class="account-section">
        <p class="account-error">{@account_error}</p>
        <button class="btn primary btn-sm" phx-click="account_back_to_type">
          Try again
        </button>
      </div>
    </.dash_panel>

    <%!-- Telegram --%>
    <.dash_panel :if={@live_action == :telegram} title="Telegram" back>
      <p class="coming-soon">Telegram configuration is coming in a future update.</p>
    </.dash_panel>

    <%!-- Integrations --%>
    <.dash_panel :if={@live_action == :integrations} title="Integrations" back>
      <div class="integration-card">
        <div class="integration-header">
          <h3>Web Search</h3>
          <span :if={@brave_mode in [:managed, :byok]} class="integration-badge ok">Active</span>
        </div>

        <%!-- Managed mode: show usage --%>
        <%= if @brave_mode == :managed do %>
          <p>Your AI agent can search the web.</p>
          <div :if={@brave_usage} class="usage-section">
            <div class="usage-bar-label">
              {@brave_usage["used"]} / {@brave_usage["limit"]} searches this month
            </div>
            <div class="usage-bar-track">
              <div
                class={[
                  "usage-bar-fill",
                  @brave_usage["used"] >= @brave_usage["limit"] && "full"
                ]}
                style={"width: #{min(100, round(@brave_usage["used"] / max(@brave_usage["limit"], 1) * 100))}%"}
              >
              </div>
            </div>
            <p :if={@brave_usage["used"] >= @brave_usage["limit"]} class="usage-limit-hint">
              Resets {@brave_usage["resets_at"]}.
            </p>
          </div>
          <div class="account-actions mt-md">
            <button
              class="btn subtle btn-sm"
              phx-click="brave_remove"
              data-confirm="Remove web search? Your agent will no longer be able to search the web."
            >
              Remove
            </button>
          </div>

        <%!-- BYOK mode: configured with own key --%>
        <% else %>
          <%= if @brave_mode == :byok do %>
            <p>Your AI agent can search the web using your Brave API key.</p>
            <div class="account-actions">
              <button
                class="btn subtle btn-sm"
                phx-click="brave_remove"
                data-confirm="Remove web search? Your agent will no longer be able to search the web."
              >
                Remove
              </button>
            </div>

          <%!-- BYOK form --%>
          <% else %>
            <%= if @brave_mode == :byok_form do %>
              <p>
                You'll need a Brave Search API key
                (<a href="https://brave.com/search/api/" target="_blank" rel="noopener">sign up here</a>
                &mdash; select the <strong>Data for Search</strong> plan).
              </p>
              <form phx-submit="brave_submit_api_key" class="account-input-group">
                <label for="brave-api-key-input">Brave API Key</label>
                <input
                  type="password"
                  name="api_key"
                  id="brave-api-key-input"
                  class={["account-input", @brave_error && "error"]}
                  placeholder="BSA-..."
                  autocomplete="off"
                  spellcheck="false"
                />
                <p :if={@brave_error} class="account-input-hint error">{@brave_error}</p>
                <button type="submit" class="btn primary mt-md">
                  Save API Key
                </button>
              </form>
              <button class="btn ghost btn-sm mt-sm" phx-click="brave_back">
                Back
              </button>

            <%!-- Not configured: show both options --%>
            <% else %>
              <p>Enable web search so your AI agent can look things up on the internet.</p>
              <p :if={@brave_error} class="account-input-hint error">{@brave_error}</p>
              <button
                class="btn primary mt-md"
                phx-click="brave_enable_managed"
                disabled={@brave_registering}
              >
                {if @brave_registering, do: "Enabling...", else: "Enable Web Search"}
              </button>
              <p class="account-input-hint">Free &middot; 200 searches per month</p>
              <div class="integration-divider">
                <span>or</span>
              </div>
              <button class="btn subtle btn-sm" phx-click="brave_show_byok">
                Use my own Brave API key
              </button>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </.dash_panel>

    <%!-- System --%>
    <.dash_panel :if={@live_action == :system} title="System" back>
      <div class="system-actions">
        <div class="system-action-group">
          <h3>Device Info</h3>
          <div class="status-grid">
            <div :if={@local_ip} class="status-item">
              <span class="status-label">Device IP</span>
              <span class="status-value">{@local_ip}</span>
            </div>
            <div :if={@node_device_id} class="status-item">
              <span class="status-label">Device ID</span>
              <span class="status-value monospace">{String.slice(@node_device_id, 0..11)}...</span>
            </div>
            <div class="status-item">
              <span class="status-label">Node retries</span>
              <span class="status-value">{@node_detail[:reconnect_attempts] || 0}</span>
            </div>
            <div class="status-item">
              <span class="status-label">Last node connect</span>
              <span class="status-value monospace">{@node_detail[:last_connected_at] || "Never"}</span>
            </div>
            <div class="status-item">
              <span class="status-label">Last node error</span>
              <span class={["status-value", if(@node_detail[:last_error], do: "warn", else: "ok")] }>
                {@node_detail[:last_error] || "None"}
              </span>
            </div>
            <div class="status-item">
              <span class="status-label">Version</span>
              <span class="status-value">{@version}</span>
            </div>
          </div>
        </div>

        <div class="system-action-group">
          <h3>Updates</h3>
          <div class="update-settings">
            <label class="toggle-row">
              <span>Auto-updates</span>
              <button
                class={["toggle-switch", @auto_update_enabled && "active"]}
                phx-click="toggle_auto_update"
                role="switch"
                aria-checked={to_string(@auto_update_enabled)}
              >
                <span class="toggle-knob"></span>
              </button>
            </label>
            <p class="setting-hint">
              {if @auto_update_enabled,
                do: "Checking for updates daily.",
                else: "Automatic updates are paused."}
            </p>
          </div>
          <div class="action-grid">
            <button
              class="btn subtle"
              phx-click="check_update"
              disabled={@update_status == :checking}
            >
              {if @update_status == :checking, do: "Checking...", else: "Check for Updates"}
            </button>
          </div>
          <div :if={@update_status} class="update-status">
            <p :if={@update_status == :checking} class="update-checking">
              Checking for updates...
            </p>
            <p :if={@update_status == :up_to_date} class="update-ok">
              System is up to date.
            </p>
            <p :if={@update_status == :downloading} class="update-info">
              Downloading v{@update_version}...
            </p>
            <p :if={@update_status == :installing} class="update-info">
              Installing v{@update_version}...
            </p>
            <p :if={@update_status == :updated} class="update-ok">
              Updated to v{@update_version}. Restarting...
            </p>
            <div
              :if={is_tuple(@update_status) and elem(@update_status, 0) == :pending_recovery_path}
              class="update-info"
            >
              <strong>Update paused for safety.</strong>
              <p>{elem(@update_status, 1)}</p>
            </div>
            <div
              :if={is_tuple(@update_status) and elem(@update_status, 0) == :pending_reauth_post_update}
              class="update-info"
            >
              <strong>Reconnect OpenAI to continue.</strong>
              <p>{elem(@update_status, 1)}</p>
              <p><.link navigate={~p"/account"} class="account-auth-link">Open Account Settings</.link></p>
            </div>
            <div
              :if={is_tuple(@update_status) and elem(@update_status, 0) == :rolled_back_auth_required}
              class="update-err"
            >
              <strong>Update rolled back.</strong>
              <p>{elem(@update_status, 1)}</p>
              <p><.link navigate={~p"/account"} class="account-auth-link">Reconnect OpenAI</.link></p>
            </div>
            <p
              :if={is_tuple(@update_status) and elem(@update_status, 0) == :error}
              class="update-err"
            >
              {elem(@update_status, 1)}
            </p>
          </div>
        </div>

        <div class="system-action-group">
          <h3>Maintenance</h3>
          <div class="action-grid">
            <button class="btn subtle" phx-click="restart_gateway">Restart Gateway</button>
            <button class="btn subtle" phx-click="run_repair">Run Repair</button>
          </div>
        </div>

        <div class="system-action-group">
          <h3>Dashboard Security</h3>
          <form phx-change="validate_change_dashboard_password" phx-submit="change_dashboard_password" class="openai-input-group" style="max-width:420px;">
            <label>Current password</label>
            <input type="password" name="current_password" value={@password_current_value} class="openai-input" autocomplete="current-password" />
            <label class="mt-md">New password</label>
            <input type="password" name="new_password" value={@password_new_value} class="openai-input" autocomplete="new-password" />
            <label class="mt-md">Confirm new password</label>
            <input type="password" name="new_password_confirm" value={@password_new_confirm_value} class="openai-input" autocomplete="new-password" />
            <.password_feedback
              min_length={Clawrig.DashboardAuth.min_length()}
              password={@password_new_value}
              strength={@password_change_strength}
              error={@password_change_error}
              success={@password_change_ok}
            />
            <button class="btn subtle mt-sm" type="submit">Change Password</button>
          </form>
          <form method="post" action="/logout" class="mt-sm">
            <input type="hidden" name="_csrf_token" value={Phoenix.Controller.get_csrf_token()} />
            <button class="btn ghost" type="submit">Log out</button>
          </form>
        </div>

        <div class="system-action-group">
          <h3>Auto-healing</h3>

          <div class="update-settings">
            <label class="toggle-row">
              <span>Enable auto-healing</span>
              <button
                class={["toggle-switch", @autoheal["enabled"] != false && "active"]}
                phx-click="toggle_autoheal"
                role="switch"
                aria-checked={to_string(@autoheal["enabled"] != false)}
              >
                <span class="toggle-knob"></span>
              </button>
            </label>
            <p class="setting-hint">
              {if @autoheal["enabled"] != false,
                do: "Gateway watchdog and daily repair are active.",
                else: "Auto-healing is paused until re-enabled."}
            </p>
          </div>

          <div class="status-grid mt-md">
            <div class="status-item">
              <span class="status-label">Health</span>
              <span class={["status-value", if(@autoheal["health"] == "healthy", do: "ok", else: "warn")] }>
                {autoheal_health_label(@autoheal["health"])}
              </span>
            </div>
            <div class="status-item">
              <span class="status-label">Last run</span>
              <span class="status-value monospace">{@autoheal["last_run_at"] || "Never"}</span>
            </div>
            <div class="status-item">
              <span class="status-label">Last result</span>
              <span class="status-value">{@autoheal["last_result"] || "unknown"}</span>
            </div>
            <div class="status-item">
              <span class="status-label">Last action</span>
              <span class="status-value">{@autoheal["last_action"] || "none"}</span>
            </div>
          </div>

          <div class="action-grid mt-md">
            <button
              class="btn subtle"
              phx-click="run_autoheal_now"
              data-confirm="Run auto-heal checks now?"
            >
              Run Fix Now
            </button>
          </div>

          <div class="log-section mt-md">
            <div class="dash-section-header">
              <h3>Auto-heal History</h3>
            </div>
            <div :if={Enum.empty?(@autoheal_log)} class="setting-hint">No recent auto-heal events.</div>
            <div :if={!Enum.empty?(@autoheal_log)} class="log-output">
              <pre><%= for entry <- @autoheal_log do %>{entry["ts"] || ""} | {entry["check"] || "check"} | {entry["action"] || "action"} | {entry["result"] || "result"} | {entry["detail"] || ""}
<% end %></pre>
            </div>
          </div>
        </div>

        <div class="system-action-group">
          <h3>Remote Access</h3>
          <%= if @tailscale == :loading do %>
            <p class="setting-hint">Checking Tailscale status...</p>
          <% else %>
            <%= if @tailscale.running && @tailscale.ip do %>
              <div class="tailscale-status tailscale-connected">
                <div class="tailscale-status-row">
                  <span class="wifi-status-badge online">
                    <span class="wifi-status-dot"></span> Connected
                  </span>
                </div>
                <div class="status-grid">
                  <div class="status-item">
                    <span class="status-label">Tailscale IP</span>
                    <span class="status-value monospace">{@tailscale.ip}</span>
                  </div>
                  <div :if={@tailscale.hostname} class="status-item">
                    <span class="status-label">Hostname</span>
                    <span class="status-value">{@tailscale.hostname}</span>
                  </div>
                </div>
                <button
                  class="btn subtle btn-sm mt-md"
                  phx-click="tailscale_disconnect"
                  data-confirm="Disconnect from Tailscale? You'll lose remote access."
                >
                  Disconnect
                </button>
              </div>
            <% else %>
              <%= if @tailscale.installed do %>
                <p class="setting-hint">
                  Connect this device to your Tailscale network for remote SSH access.
                </p>
                <form phx-submit="tailscale_connect" class="account-input-group">
                  <label for="tailscale-key-input">Auth Key</label>
                  <input
                    type="password"
                    name="auth_key"
                    id="tailscale-key-input"
                    class={["account-input", @tailscale_error && "error"]}
                    placeholder="tskey-auth-..."
                    autocomplete="off"
                    spellcheck="false"
                  />
                  <p :if={@tailscale_error} class="account-input-hint error">{@tailscale_error}</p>
                  <p :if={!@tailscale_error} class="account-input-hint">
                    Get a key from your <a href="https://login.tailscale.com/admin/settings/keys" target="_blank" rel="noopener">Tailscale admin console</a>
                  </p>
                  <p :if={@dev_tailscale_bypass_enabled} class="account-input-hint">
                    Dev mode: use a mock key like <code>tskey-test-local</code> to simulate connect/disconnect.
                  </p>
                  <button
                    type="submit"
                    class="btn primary mt-md"
                    disabled={@tailscale_connecting}
                  >
                    {if @tailscale_connecting, do: "Connecting...", else: "Connect"}
                  </button>
                </form>
              <% else %>
                <p class="setting-hint">
                  Tailscale is not installed on this device. Install it to enable remote SSH access.
                </p>
                <p :if={@tailscale_error} class="account-input-hint error mt-sm">{@tailscale_error}</p>
                <%= if @dev_tailscale_bypass_enabled do %>
                  <button class="btn primary mt-md" phx-click="tailscale_mock_install">
                    Mock Install (Dev)
                  </button>
                <% else %>
                  <button
                    class="btn primary mt-md"
                    phx-click="tailscale_install"
                    disabled={@tailscale_installing}
                  >
                    {if @tailscale_installing, do: "Installing...", else: "Install Tailscale"}
                  </button>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <div class="system-action-group system-danger-zone">
          <h3>Danger Zone</h3>
          <div class="action-grid">
            <button
              class="btn danger"
              phx-click="reboot"
              data-confirm="Are you sure you want to reboot the device?"
            >
              Reboot Device
            </button>
          </div>
        </div>
      </div>

      <div class="log-section">
        <div class="dash-section-header">
          <h3>Logs</h3>
          <button class="btn subtle btn-sm" phx-click="view_logs">Refresh</button>
        </div>
        <div :if={@logs} class="log-output">
          <pre>{@logs}</pre>
        </div>
      </div>
    </.dash_panel>
  </section>
</section>
