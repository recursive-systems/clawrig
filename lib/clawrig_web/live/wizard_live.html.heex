<section class="shell">
  <header class="shell-head">
    <h1>
      <img src={~p"/images/favicon.png"} alt="" class="shell-logo" />
      <span class="shell-wordmark">Claw<span class="rig">Rig</span></span>
    </h1>
    <div class="step-meta">
      Step {step_number(@step)} of {length(@steps)} &middot; {step_title(@step)}
    </div>
  </header>

  <section class="progress">
    <div class="progress-track">
      <div class="progress-bar" style={"width: #{step_progress(@step)}%"}></div>
    </div>
    <ol class="step-dots">
      <li :for={{s, i} <- Enum.with_index(@steps)} class={if i <= step_index(@step), do: "active"}>
      </li>
    </ol>
  </section>

  <section class="stage" aria-live="polite">
    <%!-- Preflight --%>
    <article
      class={panel_class(@step, :preflight)}
      phx-hook="AutoRun"
      id="preflight-panel"
      data-event="run_preflight"
      data-run={to_string(!@preflight_done)}
    >
      <div class="check-center">
        <div class="check-list">
          <div class="check-item">
            <div class="check-icon-wrap">
              <div :if={@preflight_status == :checking} class="check-spinner"></div>
              <svg :if={@preflight_status == :pass} class="check-ok" viewBox="0 0 36 36">
                <circle class="check-ok-circle" cx="18" cy="18" r="16" fill="none" />
                <path class="check-ok-mark" fill="none" d="M11 19l4 4 10-10" />
              </svg>
              <svg :if={@preflight_status == :fail} class="check-fail" viewBox="0 0 36 36">
                <circle class="check-fail-circle" cx="18" cy="18" r="16" fill="none" />
                <path class="check-fail-x" fill="none" d="M13 13l10 10M23 13l-10 10" />
              </svg>
              <div :if={@preflight_status == nil} class="check-spinner"></div>
            </div>
            <span class={["check-label", preflight_label_class(@preflight_status)]}>
              {preflight_label(@preflight_status)}
            </span>
          </div>
        </div>
        <h2 class={preflight_title_class(@preflight_status)}>
          {preflight_title(@preflight_status)}
        </h2>
        <p>{preflight_desc(@preflight_status)}</p>
        <button :if={@preflight_status == :fail} class="btn subtle" phx-click="run_preflight">
          Retry
        </button>
      </div>
    </article>

    <%!-- AI Provider --%>
    <article class={panel_class(@step, :provider)} id="provider-panel">
      <div class="openai-center">
        <%!-- Choose provider type --%>
        <div :if={@provider_sub == :choose_type} class="openai-sub active">
          <h2>{provider_title(@provider_sub)}</h2>
          <p>{provider_desc(@provider_sub)}</p>
          <div class="provider-type-cards">
            <button class="provider-type-card" phx-click="choose_openai">
              <div class="provider-type-icon">
                <img alt="OpenAI" src={~p"/images/openai-mark.svg"} />
              </div>
              <div class="provider-type-info">
                <strong>OpenAI</strong>
                <span>Sign in or use an API key</span>
              </div>
            </button>
            <button class="provider-type-card" phx-click="choose_compatible">
              <div class="provider-type-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2L2 7l10 5 10-5-10-5z" />
                  <path d="M2 17l10 5 10-5" />
                  <path d="M2 12l10 5 10-5" />
                </svg>
              </div>
              <div class="provider-type-info">
                <strong>Other Provider</strong>
                <span>LiteLLM, Fireworks, Groq, or any OpenAI-compatible API</span>
              </div>
            </button>
          </div>
        </div>

        <%!-- OpenAI: choose auth method --%>
        <div :if={@provider_sub == :openai_choose} class="openai-sub active">
          <div class="openai-icon-wrap">
            <div class="openai-logo">
              <img alt="OpenAI" src={~p"/images/openai-mark.svg"} />
            </div>
          </div>
          <h2>{provider_title(@provider_sub)}</h2>
          <p>{provider_desc(@provider_sub)}</p>
          <button class="btn openai" phx-click="openai_start_device_code">
            <img alt="" src={~p"/images/openai-mark.svg"} /> Sign in with OpenAI
          </button>
          <button
            class="btn subtle"
            phx-click="openai_use_api_key"
            style="margin-top:10px"
          >
            Use API key instead
          </button>
          <button
            class="btn ghost btn-sm"
            phx-click="provider_back_to_type"
            style="margin-top:16px"
          >
            Back
          </button>
        </div>

        <%!-- OpenAI: device code polling --%>
        <div :if={@provider_sub == :openai_device_code} class="openai-sub active" id="openai-device-code" phx-hook="PageFocus">
          <%= if @openai_resuming do %>
            <div class="openai-icon-wrap">
              <div class="check-spinner"></div>
            </div>
            <h2>Completing sign-in…</h2>
            <p>Checking your authorization with OpenAI.</p>
            <button
              class="btn ghost btn-sm"
              phx-click="openai_back_to_choose"
              style="margin-top:16px"
            >
              Start over
            </button>
          <% else %>
            <h2>{provider_title(@provider_sub)}</h2>
            <p>{provider_desc(@provider_sub)}</p>

            <div :if={@openai_user_code} class="device-code-display">
              <span class="device-code-value" id="device-code-text">{@openai_user_code}</span>
              <button
                class="btn subtle btn-sm"
                id="copy-device-code"
                phx-hook="CopyToClipboard"
                data-text={@openai_user_code}
              >
                Copy
              </button>
            </div>

            <div class="openai-qr-row">
              <div
                class="tg-qr hide-mobile"
                id="openai-qr-device"
                phx-hook="QRCode"
                data-url="https://auth.openai.com/codex/device"
              >
              </div>
              <p class="tg-qr-label hide-mobile">
                Scan to open <strong>auth.openai.com</strong>
              </p>
              <a
                href="https://auth.openai.com/codex/device"
                target="_blank"
                class="btn primary show-mobile"
              >
                Open auth.openai.com
              </a>
            </div>

            <div :if={@openai_polling} class="tg-polling">
              <div class="tg-polling-dot"></div>
              <span>Waiting for authorization…</span>
            </div>

            <button
              class="btn ghost btn-sm"
              phx-click="openai_back_to_choose"
              style="margin-top:12px"
            >
              Cancel
            </button>
          <% end %>
        </div>

        <%!-- OpenAI: API key paste --%>
        <div :if={@provider_sub == :openai_api_key} class="openai-sub active">
          <h2>{provider_title(@provider_sub)}</h2>
          <p>{provider_desc(@provider_sub)}</p>
          <div class="openai-instructions">
            <ol class="openai-steps">
              <li>
                <span class="openai-step-num">1</span>
                <div>
                  Go to
                  <a
                    href="https://platform.openai.com/api-keys"
                    target="_blank"
                    class="openai-link"
                  >
                    platform.openai.com/api-keys
                  </a>
                </div>
              </li>
              <li>
                <span class="openai-step-num">2</span>
                <div>Click <strong>Create new secret key</strong></div>
              </li>
              <li>
                <span class="openai-step-num">3</span>
                <div>Copy the key and paste it below</div>
              </li>
            </ol>
            <form phx-submit="submit_api_key" class="openai-input-group">
              <label for="api-key-input">API key</label>
              <input
                type="password"
                name="api_key"
                id="api-key-input"
                class={["openai-input", @provider_error && "error"]}
                placeholder="sk-..."
                autocomplete="off"
                spellcheck="false"
              />
              <p class={["openai-input-hint", @provider_error && "error"]}>
                {if @provider_error,
                  do: @provider_error,
                  else: raw("Starts with <code>sk-</code>")}
              </p>
              <button
                type="submit"
                class="btn primary"
                disabled={@provider_status == :saving}
                style="margin-top:12px"
              >
                {if @provider_status == :saving, do: "Saving...", else: "Save API key"}
              </button>
            </form>
          </div>
          <button
            class="btn ghost btn-sm"
            phx-click="openai_back_to_choose"
            style="margin-top:8px"
          >
            Back
          </button>
        </div>

        <%!-- OpenAI-Compatible: endpoint form --%>
        <div :if={@provider_sub == :compat_form} class="openai-sub active">
          <h2>{provider_title(@provider_sub)}</h2>
          <p>{provider_desc(@provider_sub)}</p>
          <form phx-submit="submit_compatible" class="openai-input-group">
            <label for="base-url-input">Base URL</label>
            <input
              type="url"
              name="base_url"
              id="base-url-input"
              class="openai-input"
              placeholder="https://litellm.example.com/v1"
              autocomplete="off"
            />
            <p class="openai-input-hint">
              The /v1 endpoint of your provider
            </p>

            <label for="compat-api-key-input" style="margin-top:12px">API Key</label>
            <input
              type="password"
              name="api_key"
              id="compat-api-key-input"
              class="openai-input"
              placeholder="sk-..."
              autocomplete="off"
            />

            <label for="model-id-input" style="margin-top:12px">Model ID</label>
            <input
              type="text"
              name="model_id"
              id="model-id-input"
              class="openai-input"
              placeholder="gpt-4o"
              autocomplete="off"
            />
            <p class="openai-input-hint">
              The model identifier your provider expects
            </p>

            <label for="display-name-input" style="margin-top:12px">Display Name <span class="openai-input-optional">(optional)</span></label>
            <input
              type="text"
              name="display_name"
              id="display-name-input"
              class="openai-input"
              placeholder="My LiteLLM Proxy"
              autocomplete="off"
            />

            <p :if={@provider_error} class="openai-input-hint error" style="margin-top:8px">
              {@provider_error}
            </p>

            <button
              type="submit"
              class="btn primary"
              disabled={@provider_status == :saving}
              style="margin-top:16px"
            >
              {if @provider_status == :saving, do: "Saving...", else: "Connect"}
            </button>
          </form>
          <button
            class="btn ghost btn-sm"
            phx-click="provider_back_to_type"
            style="margin-top:8px"
          >
            Back
          </button>
        </div>

        <%!-- Done --%>
        <div :if={@provider_sub == :done} class="openai-sub active">
          <div class="openai-icon-wrap">
            <div class="openai-check">
              <svg class="openai-check-svg" viewBox="0 0 52 52">
                <circle class="openai-check-circle" cx="26" cy="26" r="24" fill="none" />
                <path class="openai-check-mark" fill="none" d="M15 27l7 7 15-15" />
              </svg>
            </div>
          </div>
          <h2 class={provider_title_class(@provider_sub)}>
            {provider_title(@provider_sub)}
          </h2>
          <p :if={@provider_type == "openai"}>{provider_desc(@provider_sub)}</p>
          <p :if={@provider_type == "openai-compatible"}>
            Connected to {@provider_name || "your provider"}.
          </p>
        </div>

        <%!-- Error --%>
        <div :if={@provider_sub == :error} class="openai-sub active">
          <div class="openai-icon-wrap">
            <div class="openai-logo">
              <%= if @provider_type == "openai" do %>
                <img alt="OpenAI" src={~p"/images/openai-mark.svg"} />
              <% else %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="12" y1="8" x2="12" y2="12" />
                  <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
              <% end %>
            </div>
          </div>
          <h2 class={provider_title_class(@provider_sub)}>
            {provider_title(@provider_sub)}
          </h2>
          <p class="error">{@provider_error}</p>
          <%= if @provider_type == "openai" do %>
            <button class="btn primary" phx-click="openai_start_device_code" style="margin-top:4px">
              Try again
            </button>
            <button
              class="btn subtle"
              phx-click="openai_use_api_key"
              style="margin-top:10px"
            >
              Use API key instead
            </button>
          <% else %>
            <button class="btn primary" phx-click="choose_compatible" style="margin-top:4px">
              Try again
            </button>
          <% end %>
          <button
            class="btn ghost btn-sm"
            phx-click="provider_back_to_type"
            style="margin-top:12px"
          >
            Change provider
          </button>
        </div>
      </div>
    </article>

    <%!-- Telegram --%>
    <article class={panel_class(@step, :telegram)}>
      <div class="tg-center">
        <%!-- Intro --%>
        <div :if={@tg_sub == :intro} class="tg-sub active">
          <div class="tg-icon-wrap">
            <div class="tg-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 2L11 13" /><polygon points="22 2 15 22 11 13 2 9 22 2" />
              </svg>
            </div>
          </div>
          <h2>Telegram</h2>
          <p class="tg-lead">
            This is how you'll talk to your Pi. Send it messages, get status updates, and control OpenClaw — all from your phone.
          </p>
          <p class="tg-prereq">
            You'll need the <strong>Telegram app</strong>
            installed on your phone (Android or iPhone).
          </p>
          <button class="btn primary" phx-click="tg_start">Set up Telegram</button>
          <p class="tg-skip-hint">or press Skip to set up later</p>
        </div>

        <%!-- Create bot --%>
        <div :if={@tg_sub == :create} class="tg-sub active">
          <h2>Create your bot</h2>
          <p class="tg-lead">
            You'll make a personal Telegram bot that connects to your Pi. It takes about 30 seconds.
          </p>
          <div class="tg-qr-row">
            <div
              class="tg-qr"
              id="tg-qr-botfather"
              phx-hook="QRCode"
              data-url="https://t.me/BotFather"
            >
            </div>
            <p class="tg-qr-label">Scan with your phone to open <strong>@BotFather</strong></p>
          </div>
          <ol class="tg-steps">
            <li>
              <span class="tg-step-num">1</span>
              <div>
                Scan the QR code above, or search for <strong>@BotFather</strong> in Telegram
              </div>
            </li>
            <li>
              <span class="tg-step-num">2</span>
              <div>Send the message <code>/newbot</code></div>
            </li>
            <li>
              <span class="tg-step-num">3</span>
              <div>
                Give your bot a name (e.g. <strong>My Pi</strong>) and a username (e.g. <strong>mypi_bot</strong>)
              </div>
            </li>
            <li>
              <span class="tg-step-num">4</span>
              <div>BotFather will reply with a token — copy it and paste it here</div>
            </li>
          </ol>
          <form phx-submit="tg_validate" class="tg-input-group">
            <label for="tg-token-input">Bot token</label>
            <input
              type="text"
              name="token"
              id="tg-token-input"
              class={["tg-input", @tg_error && "error"]}
              placeholder="123456789:ABCdef..."
              autocomplete="off"
              spellcheck="false"
            />
            <p class={["tg-input-hint", @tg_error && "error"]}>
              {if @tg_error,
                do: @tg_error,
                else: raw("Looks like <code>123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11</code>")}
            </p>
            <button
              type="submit"
              class="btn primary"
              disabled={@tg_status == :validating}
              style="margin-top:12px"
            >
              {if @tg_status == :validating, do: "Validating...", else: "Connect bot"}
            </button>
          </form>
        </div>

        <%!-- Chat --%>
        <div :if={@tg_sub == :chat} class="tg-sub active">
          <div class="tg-icon-wrap">
            <div class="tg-icon pulse">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
              </svg>
            </div>
          </div>
          <h2>Say hello to your bot</h2>
          <div :if={@tg_bot_username} class="tg-qr-row">
            <div
              class="tg-qr"
              id="tg-qr-bot"
              phx-hook="QRCode"
              data-url={"https://t.me/#{@tg_bot_username}"}
            >
            </div>
            <p class="tg-qr-label">Scan to open <strong>@{@tg_bot_username}</strong></p>
          </div>
          <p class="tg-lead">
            Scan the QR code or search for your bot in Telegram. Send it any message — like "hello".
          </p>
          <div class="tg-polling">
            <div class="tg-polling-dot"></div>
            <span>Waiting for your message…</span>
          </div>
        </div>

        <%!-- Done --%>
        <div :if={@tg_sub == :done} class="tg-sub active">
          <div class="tg-icon-wrap">
            <div class="tg-check">
              <svg class="tg-check-svg" viewBox="0 0 52 52">
                <circle class="tg-check-circle" cx="26" cy="26" r="24" fill="none" />
                <path class="tg-check-mark" fill="none" d="M15 27l7 7 15-15" />
              </svg>
            </div>
          </div>
          <h2 class="tg-connected">Connected</h2>
          <p class="tg-lead">Your bot is linked. You'll get notifications right on your phone.</p>
        </div>
      </div>
    </article>

    <%!-- Receipt --%>
    <article class={panel_class(@step, :receipt)}>
      <div class="done-center">
        <div class={["done-icon-wrap", @step == :receipt && "visible"]} id="done-icon">
          <svg class="done-check-svg" viewBox="0 0 64 64">
            <circle class="done-check-circle" cx="32" cy="32" r="30" fill="none" />
            <path class="done-check-mark" fill="none" d="M19 34l8 8 18-18" />
          </svg>
        </div>
        <h2>You're all set</h2>
        <p>Your Pi is configured. OpenClaw will start automatically in the background.</p>

        <div class="ip-gate-card">
          <h3 class="ip-gate-title">Your dashboard address</h3>
          <div class="ip-gate-addresses">
            <code :if={@local_ip} class="ip-gate-addr">http://{@local_ip}</code>
            <code class="ip-gate-addr">{@mdns_url}</code>
          </div>
          <p class="ip-gate-hint">
            Bookmark this or write it down — you'll need it to reach your dashboard.
            <span :if={@tg_chat_id}>You can also ask your Telegram bot "Where's my dashboard?" anytime.</span>
          </p>
          <label class="ip-gate-confirm" phx-click="confirm_ip">
            <input type="checkbox" checked={@ip_confirmed} />
            <span>I've saved my dashboard address</span>
          </label>
        </div>

        <p :if={@finish_message} class="helper">{@finish_message}</p>
        <button class="btn primary" phx-click="finish" disabled={!@ip_confirmed || @finishing}>
          {if @finishing, do: "Finishing...", else: "Finish setup"}
        </button>
      </div>
    </article>
  </section>

  <footer class="shell-foot">
    <button
      class={["btn ghost", at_start?(@step) && "nav-hidden"]}
      phx-click="nav_prev"
      disabled={at_start?(@step)}
    >
      Back
    </button>
    <button
      class={["btn primary", at_end?(@step) && "nav-hidden"]}
      phx-click="nav_next"
      disabled={!can_next?(assigns) || at_end?(@step)}
    >
      {next_label(@step, assigns)}
    </button>
  </footer>
</section>
